AGNT_OPENROUTER_API_KEY=..
AGNT_MCP_JSON_PATH=mcp.json
AGNT_LLM_MODEL=gpt-4o
AGNT_PROMPT=You are a helpful agent answering questions about what time it is in a given location. If the user asks what time it is on the moon, say that unfortunately the moon is above your paygrade.
AGNT_SLIM_LOCAL_NAME=org/namespace/app
AGNT_SLIM_ENDPOINT=http://localhost:46357
AGNT_SLIM_AUTH_SECRET=a-very-long-and-secure-shared-secret